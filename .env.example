# Copy this file to .env before starting the full local stack. These values are
# development defaults only; never reuse them outside local development.
POSTGRES_DB=promptshield
POSTGRES_USER=promptshield
POSTGRES_PASSWORD=promptshield-dev-password
KEYCLOAK_DB_PASSWORD=keycloak-dev-password
REDIS_PASSWORD=redis-dev-password
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin-change-me
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin-change-me
APP_AUDIT_FINGERPRINT_KEY=local-development-audit-key-change-me

# Host ports (change if they clash with another local service)
APP_PORT=8080
KEYCLOAK_PORT=8081
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
