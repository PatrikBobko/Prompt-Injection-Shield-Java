{
  "realm": "promptshield",
  "displayName": "Prompt Injection Shield",
  "enabled": true,
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": false,
  "roles": {
    "realm": [
      {
        "name": "scan",
        "description": "May submit and view prompt-injection scans"
      },
      {
        "name": "admin",
        "description": "May administer Prompt Injection Shield"
      }
    ]
  },
  "clients": [
    {
      "clientId": "promptshield-cli",
      "name": "Prompt Shield local CLI",
      "description": "Development-only client for requesting a demo access token",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": true,
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": false,
      "implicitFlowEnabled": false,
      "frontchannelLogout": true,
      "fullScopeAllowed": true,
      "protocolMappers": [
        {
          "name": "promptshield-api-audience",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.client.audience": "promptshield-api",
            "access.token.claim": "true",
            "id.token.claim": "false",
            "introspection.token.claim": "true"
          }
        }
      ]
    },
    {
      "clientId": "promptshield-api",
      "name": "Prompt Injection Shield API",
      "description": "Audience registered for the protected API",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": true,
      "implicitFlowEnabled": false,
      "frontchannelLogout": true,
      "fullScopeAllowed": true,
      "secret": "local-development-only-change-me"
    }
  ],
  "users": [
    {
      "username": "demo",
      "enabled": true,
      "email": "demo@promptshield.local",
      "emailVerified": true,
      "firstName": "Demo",
      "lastName": "User",
      "realmRoles": [
        "scan"
      ],
      "credentials": [
        {
          "type": "password",
          "value": "demo-password-change-me",
          "temporary": false
        }
      ]
    }
  ]
}
